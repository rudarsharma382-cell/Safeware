{
  "builds": [
    {
      "src": "app.py",
      "use": "@vercel/python"
    }
  ],
  "routes": [
    {
      "src": "/static/(.*)",
      "dest": "/static/$1"
    },
    {
      "src": "/interstellar.mp3",
      "dest": "/interstellar.mp3"
    },
    {
      "src": "/(.*)",
      "dest": "app.py"
    }
  ]
}
